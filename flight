                travelerBadge.innerText = "Richard Russell Scheibner";
                showToast("Switched view to Richard Scheibner");
            }
        }

        // Filter flights by outbound or return directions
        function filterLeg(direction) {
            currentLegFilter = direction;
            const btnAll = document.getElementById('btn-filter-all');
            const btnOutbound = document.getElementById('btn-filter-outbound');
            const btnReturn = document.getElementById('btn-filter-return');
            const flightCards = document.querySelectorAll('.flight-card');

            // Reset tab styling
            const inactiveClass = "px-4 py-1.5 rounded-lg text-xs font-bold transition duration-200 text-slate-500 hover:text-slate-800";
            const activeClass = "px-4 py-1.5 rounded-lg text-xs font-bold transition duration-200 bg-white text-slate-800 shadow";
            
            btnAll.className = inactiveClass;
            btnOutbound.className = inactiveClass;
            btnReturn.className = inactiveClass;

            if (direction === 'all') {
                btnAll.className = activeClass;
            } else if (direction === 'outbound') {
                btnOutbound.className = activeClass;
            } else if (direction === 'return') {
                btnReturn.className = activeClass;
            }

            // Show/Hide relevant elements
            flightCards.forEach(card => {
                const cardDir = card.getAttribute('data-direction');
                if (direction === 'all') {
                    card.style.display = 'block';
                } else if (direction === cardDir) {
                    card.style.display = 'block';
                } else {
                    card.style.display = 'none';
                }
            });
        }
    </script>
</body>
